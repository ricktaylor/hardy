#!/bin/bash
# Start NASA cFS BPNode for interop testing
#
# This script creates the required storage directory and starts the
# cFS core executable. It runs in the binary directory so cFS can
# find its table files and startup script.

set -e

CFS_DIR="/opt/cfs/echo"

# Create storage directory required by BPNode
mkdir -p "$CFS_DIR/storage"

# Raise POSIX message queue limits (cFS needs deep queues)
if [ -w /proc/sys/fs/mqueue/msg_max ]; then
    echo 500 > /proc/sys/fs/mqueue/msg_max 2>/dev/null || true
fi

cd "$CFS_DIR"

# cFS expects startup script at ./cf/cfe_es_startup.scr
mkdir -p cf
cp -n /opt/cfs/cfe_es_startup.scr cf/ 2>/dev/null || true

echo "Starting cFS BPNode (STCP echo mode)..."
echo "  STCP listen port: 4501"
echo "  STCP connect to:  127.0.0.1:4551"

# Start cFS in background, then send commands to start contacts
./core-echo &
CFS_PID=$!

# Wait for cFS to initialize
sleep 5

# Send commands via cmdUtil through CI_LAB (UDP port 1234)
# BPNODE_CMD_MID = 0x1838 (topic 0x38), little-endian
CMDUTIL="/opt/cfs/host/cmdUtil --port 1234 --endian=LE --pktid=0x1838"

# Add Application for channels (CC=14), Setup Contact (CC=29),
# Start Application (CC=17), Start Contact (CC=30)
# Channel 0 was auto-added during init; add Channel 1 for echo outbound
echo "Adding BPNode application for channel 1..."
$CMDUTIL --cmdcode=14 --uint32=1 2>/dev/null || true
sleep 1

echo "Starting BPNode applications..."
$CMDUTIL --cmdcode=17 --uint32=0 2>/dev/null || true
$CMDUTIL --cmdcode=17 --uint32=1 2>/dev/null || true
sleep 1

echo "Setting up BPNode contact 0..."
$CMDUTIL --cmdcode=29 --uint32=0 2>/dev/null || true
sleep 1

echo "Starting BPNode contact 0..."
$CMDUTIL --cmdcode=30 --uint32=0 2>/dev/null || true
sleep 2

echo "BPNode startup commands sent."

# Wait for cFS process
wait $CFS_PID
