#!/bin/bash
# Start NASA cFS BPNode for interop testing
#
# Creates the storage directory, starts the cFS core executable, and
# sends BPNode management commands to configure the echo topology.

set -e

CFS_DIR="/opt/cfs/echo"

mkdir -p "$CFS_DIR/storage"

# Raise POSIX message queue limits (cFS needs deep queues)
if [ -w /proc/sys/fs/mqueue/msg_max ]; then
    echo 500 > /proc/sys/fs/mqueue/msg_max 2>/dev/null || true
fi

cd "$CFS_DIR"

# Select the per-test startup script: TEST 1 (echo) loads echo_app, TEST 2
# (ping) loads ping_app. Force-overwrite the installed default in cf/.
TEST_MODE="${TEST_MODE:-echo}"
mkdir -p cf
cp -f "/opt/cfs/cfe_es_startup_${TEST_MODE}.scr" cf/cfe_es_startup.scr

echo "Starting cFS BPNode (STCP, TEST_MODE=${TEST_MODE})..."
echo "  STCP listen port: 4501"
echo "  STCP connect to:  127.0.0.1:4551"

./core-echo &
CFS_PID=$!

sleep 5

# BPNode commands via CI_LAB (UDP port 1234).
# cFS renamed the command sender cmdUtil -> cmd_send in v7.0.1; accept either,
# and fail loudly if neither is present. A silent miss here means no setup
# commands -> no contact -> no STCP listener, which is exactly how the v7.0.1
# rename masqueraded as a "cFS did not start listening" failure.
if [ -x /opt/cfs/host/cmd_send ]; then
    CMDUTIL=/opt/cfs/host/cmd_send
elif [ -x /opt/cfs/host/cmdUtil ]; then
    CMDUTIL=/opt/cfs/host/cmdUtil
else
    echo "ERROR: cFS command sender not found in /opt/cfs/host" >&2
    exit 1
fi

CMDUTIL_ARGS=(--port 1234 --endian=LE --pktid=0x1838)

send_bpnode_cmd() {
    local description="$1"
    shift

    echo "$description"
    if ! "$CMDUTIL" "${CMDUTIL_ARGS[@]}" "$@"; then
        echo "WARNING: cmdUtil failed while sending: $description" >&2
    fi
}

# Channel 0 is auto-added and auto-started during init, but the auto-start
# does not activate SB subscriptions.  Stop it, then restart so the ADU
# proxy table (including the loaded app's subscription) takes full effect.
send_bpnode_cmd "Adding BPNode application for channel 1..." --cmdcode=14 --uint32=1
sleep 1

send_bpnode_cmd "Stopping auto-started Channel 0..." --cmdcode=18 --uint32=0
sleep 1

send_bpnode_cmd "Starting BPNode application for channel 0..." --cmdcode=17 --uint32=0
send_bpnode_cmd "Starting BPNode application for channel 1..." --cmdcode=17 --uint32=1
sleep 1

send_bpnode_cmd "Setting up BPNode contact 0..." --cmdcode=29 --uint32=0
sleep 1

send_bpnode_cmd "Starting BPNode contact 0..." --cmdcode=30 --uint32=0
sleep 2

echo "BPNode startup commands sent."

wait $CFS_PID
