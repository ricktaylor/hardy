#!/bin/sh
# HDTN interop test wrapper script
#
# This script starts hdtn-one-process with configuration suitable for
# interoperability testing with other DTN implementations.
#
# Environment variables:
#   NODE_ID     - Node number for IPN EID (default: 10)
#   TCPCL_PORT  - TCPCLv4 listening port (default: 4556)
#
# Additional arguments are passed to hdtn-one-process.

NODE_ID=${NODE_ID:-10}
TCPCL_PORT=${TCPCL_PORT:-4556}
CONFIG_DIR="/opt/hdtn/config_files"
RUNTIME_DIR="/tmp/hdtn_runtime"

mkdir -p "$RUNTIME_DIR"

echo "HDTN Interop Testing"
echo "  Node ID:     $NODE_ID (ipn:$NODE_ID.0)"
echo "  Echo:        ipn:$NODE_ID.2047"
echo "  TCPCLv4:     port $TCPCL_PORT"
echo ""

# Generate runtime configuration for interop testing
# This creates a minimal config for single-node TCPCLv4 testing
# Config format is for HDTN 1.3.x
cat > "$RUNTIME_DIR/hdtn_config.json" << EOF
{
    "hdtnConfigName": "interop_test",
    "userInterfaceOn": false,
    "mySchemeName": "ipn",
    "myNodeId": $NODE_ID,
    "myBpEchoServiceId": 2047,
    "myCustodialSsp": "custody",
    "myCustodialServiceId": 0,
    "myRouterServiceId": 100,
    "isAcsAware": true,
    "acsMaxFillsPerAcsPacket": 100,
    "acsSendPeriodMilliseconds": 1000,
    "retransmitBundleAfterNoCustodySignalMilliseconds": 10000,
    "maxBundleSizeBytes": 10000000,
    "maxIngressBundleWaitOnEgressMilliseconds": 2000,
    "bufferRxToStorageOnLinkUpSaturation": false,
    "maxLtpReceiveUdpPacketSizeBytes": 65536,
    "neighborDepletedStorageDelaySeconds": 0,
    "fragmentBundlesLargerThanBytes": 0,
    "enforceBundlePriority": false,
    "zmqBoundRouterPubSubPortPath": 10200,
    "zmqBoundTelemApiPortPath": 10305,
    "inductsConfig": {
        "inductConfigName": "interop_inducts",
        "inductVector": [
            {
                "name": "tcpclv4_induct",
                "convergenceLayer": "tcpcl_v4",
                "boundPort": $TCPCL_PORT,
                "numRxCircularBufferElements": 200,
                "numRxCircularBufferBytesPerElement": 20000,
                "keepAliveIntervalSeconds": 15,
                "tcpclV4MyMaxRxSegmentSizeBytes": 200000,
                "tlsIsRequired": false,
                "certificatePemFile": "",
                "privateKeyPemFile": "",
                "diffieHellmanParametersPemFile": ""
            }
        ]
    },
    "outductsConfig": {
        "outductConfigName": "interop_outducts",
        "outductVector": [
            {
                "name": "dummy_outduct",
                "convergenceLayer": "tcpcl_v4",
                "nextHopNodeId": 99,
                "remoteHostname": "127.0.0.1",
                "remotePort": 4559,
                "maxNumberOfBundlesInPipeline": 50,
                "maxSumOfBundleBytesInPipeline": 50000000,
                "keepAliveIntervalSeconds": 17,
                "tcpclAllowOpportunisticReceiveBundles": true,
                "tcpclV4MyMaxRxSegmentSizeBytes": 200000,
                "tryUseTls": false,
                "tlsIsRequired": false,
                "useTlsVersion1_3": false,
                "doX509CertificateVerification": false,
                "verifySubjectAltNameInX509Certificate": false,
                "certificationAuthorityPemFileForVerification": ""
            }
        ]
    },
    "storageConfig": {
        "storageImplementation": "asio_single_threaded",
        "tryToRestoreFromDisk": false,
        "autoDeleteFilesOnExit": true,
        "totalStorageCapacityBytes": 1000000000,
        "storageDeletionPolicy": "never",
        "storageDiskConfigVector": [
            {
                "name": "disk0",
                "storeFilePath": "$RUNTIME_DIR/bundles"
            }
        ]
    }
}
EOF

# Generate contact plan (cut-through mode, unlimited rate)
# Dummy contacts for node 99 (matching the dummy outduct)
cat > "$RUNTIME_DIR/contact_plan.json" << EOF
{
    "contacts": [
        {
            "contact": 0,
            "source": 99,
            "dest": $NODE_ID,
            "startTime": 0,
            "endTime": 86400,
            "rateBitsPerSec": 0,
            "owlt": 1
        },
        {
            "contact": 1,
            "source": $NODE_ID,
            "dest": 99,
            "startTime": 0,
            "endTime": 86400,
            "rateBitsPerSec": 0,
            "owlt": 1
        }
    ]
}
EOF

echo "Starting HDTN daemon..."
exec hdtn-one-process \
    --hdtn-config-file="$RUNTIME_DIR/hdtn_config.json" \
    --contact-plan-file="$RUNTIME_DIR/contact_plan.json" \
    "$@"
